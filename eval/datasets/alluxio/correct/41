alluxio.user.short.circuit.preferred=true
# Description: When short circuit and domain socket both enabled, prefer to use short circuit.

alluxio.master.web.bind.host=127.0.0.1
# Description: The hostname Alluxio master web UI binds to.

alluxio.worker.data.folder.permissions=rwxrwxrwx
# Description: The permission set for the worker data folder. If short circuit is used this folder should be accessible by all users (rwxrwxrwx).

alluxio.master.worker.timeout=1min
# Description: Timeout between master and worker indicating a lost worker.

alluxio.worker.tieredstore.level2.watermark.low.ratio=1.4
# Description: The low watermark of the space in the third storage tier (a value between 0 and 1).

alluxio.worker.evictor.class=
# Description: The strategy that a worker uses to evict block files when a storage layer runs out of space. Valid options include `alluxio.worker.block.evictor.LRFUEvictor`, `alluxio.worker.block.evictor.GreedyEvictor`, `alluxio.worker.block.evictor.LRUEvictor`, `alluxio.worker.block.evictor.PartialLRUEvictor`.

fs.cos.connection.max=2048
# Description: The maximum number of COS connections.

alluxio.master.worker.info.cache.refresh.time=20sec
# Description: The worker information list will be refreshed after being cached for this time period. If the refresh time is too big, operations on the job servers or clients may fail because of the stale worker info. If it is too small, continuously updating worker information may case lock contention in the block master

