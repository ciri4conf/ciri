alluxio.underfs.s3.default.mode=999
# Description: Mode (in octal notation) for S3 objects if mode cannot be discovered.

alluxio.worker.remote.io.slow.threshold=20s
# Description: The time threshold for when a worker remote IO (read or write) of a single buffer is considered slow. When slow IO occurs, it is logged by a sampling logger.

alluxio.master.mount.table.root.alluxio=/valid/file2
# Description: Alluxio root mount point.

alluxio.user.block.read.retry.sleep.base=500ms
# Description: N/A

alluxio.master.backup.state.lock.forced.duration=30min
# Description: Exclusive locking of the state-lock will timeout after this duration is spent on forced phase.

alluxio.worker.network.netty.boss.threads=2
# Description: How many threads to use for accepting new requests.

alluxio.worker.principal=
# Description: Kerberos principal for Alluxio worker.

alluxio.user.metrics.collection.enabled=false
# Description: Enable collecting the client-side metrics and heartbeat them to master

